{
  "name": "latex-citation-statistics",
  "displayName": "LaTeX Citation Statistics",
  "description": "Real-time citation manager and tracker for LaTeX. Fully offline.",
  "license": "MIT",
  "version": "1.2.2",
  "publisher": "ActiveClientMods",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ActiveClientMods/latex-citation-statistics.git"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/*.bib",
    "workspaceContains:**/*.tex"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "latexCitationStatistics",
          "title": "LaTeX Citations",
          "icon": "media/citation.svg"
        }
      ]
    },
    "views": {
      "latexCitationStatistics": [
        {
          "id": "latexCitationStatistics.view",
          "type": "webview",
          "name": "Citations",
          "icon": "media/citation.svg",
          "contextualTitle": "LaTeX Citations"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "latexCitationStatistics.view",
        "contents": "No BibTeX entries found yet.\nOpen a workspace containing .bib and .tex files to see your citation usage here."
      }
    ],
    "commands": [
      {
        "command": "latex-citation-statistics.refresh",
        "title": "Refresh Citations",
        "category": "LaTeX Citations",
        "icon": "$(refresh)"
      },
      {
        "command": "latex-citation-statistics.goToUsage",
        "title": "Go to Usage",
        "category": "LaTeX Citations",
        "icon": "$(go-to-file)"
      },
      {
        "command": "latex-citation-statistics.goToBibDefinition",
        "title": "Go to Bib Definition",
        "category": "LaTeX Citations",
        "icon": "$(book)"
      },
      {
        "command": "latex-citation-statistics.copyCitationKey",
        "title": "Copy Citation Key",
        "category": "LaTeX Citations",
        "icon": "$(copy)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "latex-citation-statistics.refresh",
          "when": "view == latexCitationStatistics.view",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "latex-citation-statistics.goToUsage",
          "when": "false"
        },
        {
          "command": "latex-citation-statistics.goToBibDefinition",
          "when": "false"
        },
        {
          "command": "latex-citation-statistics.copyCitationKey",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "LaTeX Citation Statistics",
      "properties": {
        "latex-citation-statistics.debounceDelay": {
          "type": "number",
          "default": 250,
          "minimum": 0,
          "markdownDescription": "Delay in milliseconds before re-parsing a document after you stop typing. Higher values reduce CPU usage while typing; lower values feel more instant."
        },
        "latex-citation-statistics.showOverview": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Show the **Overview** node with total, used, unused, and citation counts at the top of the Citations view. The Overview is hidden automatically while a search or filter is active."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run package",
    "compile": "bun run check-types && bun run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "bun run check-types && bun run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "bun run compile-tests && bun run compile && bun run lint",
    "check-types": "tsc --noEmit",
    "lint": "oxlint src",
    "test": "vscode-test",
    "vsce:package": "bunx @vscode/vsce package --no-dependencies",
    "vsce:publish": "bunx @vscode/vsce publish --no-dependencies",
    "vsce:login": "bunx @vscode/vsce login",
    "vsce:verify": "bunx @vscode/vsce verify-pat",
    "ovsx:publish": "bunx ovsx publish --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "oxlint": "^1.75.0",
    "esbuild": "^0.28.1",
    "npm-run-all": "^4.1.5",
    "typescript": "7.0.2",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
